HOST=127.0.0.1
PORT=19100
DATA_DIR=./data
SQLITE_PATH=./data/projectego-chat.sqlite
DEV_AUTH_BYPASS=true
TRUST_AUTHELIA_HEADERS=false
AUTH_MODE=local
SESSION_SECRET=change-me-to-a-long-random-secret
REGISTRATION_ENABLED=true
REGISTRATION_INVITE_CODE=change-me
COOKIE_SECURE=false
LLM_PROVIDER=mock
CODEX_AGENT_URL=
CODEX_AGENT_TOKEN=
CODEX_FALLBACK_TO_MOCK=true
PLANE_BASE_URL=
PLANE_WORKSPACE=projectego
PLANE_API_KEY=
N8N_BASE_URL=
N8N_WEBHOOK_TOKEN=

# ProjectEGO PM runs as a separate service. Do not pass Dashboard/agent secrets
# such as CODEX_AGENT_TOKEN, AGENT_ATTACHMENT_TOKEN, JOB_CALLBACK_TOKEN,
# N8N_WEBHOOK_TOKEN, PLANE_API_KEY, or DASHBOARD_INTERNAL_BASE_URL to PM.
PM_HOST=127.0.0.1
PM_PORT=19110
PM_DATA_DIR=./pm-data
PM_ATTACHMENTS_DIR=./pm-data/attachments
PM_DATABASE_URL=postgres://projectego_pm_app:change-me@localhost:5432/projectego
PM_PUBLIC_BASE_URL=https://pm.project-ego.online
PM_TRUST_AUTHELIA_HEADERS=true
PM_DEV_AUTH_BYPASS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=pm@project-ego.online
SMTP_TLS=true
